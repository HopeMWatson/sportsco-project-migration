# ─────────────────────────────────────────────────────────────────────────────
# .env  —  NON-SENSITIVE config only
#
# Sensitive credentials (DBT_TOKEN, Snowflake password) are NOT stored here.
# They live in AWS Secrets Manager and are fetched at runtime by:
#
#   scripts/tf_with_secrets.sh    → for all `make plan / apply` targets
#   scripts/export_env_secrets.sh → for Python script targets (backup-runs, etc.)
#
# Populate this file automatically after Phase 1 apply:
#   bash scripts/export_env_secrets.sh > .env
#
# Or source secrets directly into your shell without writing to disk:
#   source <(bash scripts/export_env_secrets.sh)
# ─────────────────────────────────────────────────────────────────────────────

DBT_HOST=https://cloud.getdbt.com/api

# ─── These are set by export_env_secrets.sh after Phase 1 apply ───────────────
DBT_ACCOUNT_ID=
DBT_VAL_PROJECT_ID=
DBT_PROD_PROJECT_ID=
DBT_PROD_VAL_ENV_ID=
S3_BUCKET=
